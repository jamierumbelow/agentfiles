{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(git worktree:*)",
      "Web Search(*)",
      "Fetch(*)"
    ],
    "additionalDirectories": [
      "~/workspace/vault"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/james.rumbelow/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/james.rumbelow/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"/Users/james.rumbelow/.claude/hooks/gsd-statusline.js\""
  },
  "sandbox": {
    "network": {
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent",
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/workspace/vault"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  }
}
